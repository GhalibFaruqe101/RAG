# ============================================================
# .env.example — Safe template. Copy to .env and fill in values.
# ⚠️  NEVER commit your actual .env file to Git!
# ============================================================

# --- LLM API Keys ---
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- LangChain / LangSmith (optional, for tracing) ---
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=LangRAG

# --- Vector Store ---
# For Pinecone (if used)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# --- Database (if applicable) ---
DATABASE_URL=

# --- App Settings ---
APP_ENV=development       # development | staging | production
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
